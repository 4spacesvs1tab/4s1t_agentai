# =============================================================================
# 4S1T Agent AI — Environment Variables
# Copy this file to .env and fill in all values before starting the service.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Core application
# -----------------------------------------------------------------------------
DEBUG=false
HOST=0.0.0.0
PORT=8000

# Must be >= 64 chars, mixed character types (letters, numbers, symbols)
SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_64

# Comma-separated allowed CORS origins (JSON list)
ALLOWED_ORIGINS=["https://yourdomain.com"]

# -----------------------------------------------------------------------------
# Database
# In Docker the path is /app/data/agent.db (inside the data/ volume).
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///data/agent.db

# -----------------------------------------------------------------------------
# LLM Provider selection (config/providers.yaml)
# Choose which provider the agent core uses.
# Supported values: nano_gpt | openrouter | openai | local_ollama
# Default: nano_gpt (matches the `active:` key in providers.yaml)
# -----------------------------------------------------------------------------
ACTIVE_PROVIDER=nano_gpt

# -----------------------------------------------------------------------------
# Nano-GPT API (core/api_client.py)
# Obtain at https://nano-gpt.com
# Only required when ACTIVE_PROVIDER=nano_gpt
# -----------------------------------------------------------------------------
NANO_GPT_API_KEY=your-nano-gpt-api-key-here
NANO_GPT_BASE_URL=https://nano-gpt.com/api/v1
NANO_GPT_SUBSCRIPTION_TIER=FREE

# -----------------------------------------------------------------------------
# OpenRouter API (https://openrouter.ai)
# Only required when ACTIVE_PROVIDER=openrouter
# Obtain API key: https://openrouter.ai/keys
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=your-openrouter-api-key-here

# -----------------------------------------------------------------------------
# Local Ollama via Open WebUI on Start9 server
# Only required when ACTIVE_PROVIDER=local_ollama
# Generate API key: https://<start9-local>/ → Profile → Settings → Account → API Keys
# -----------------------------------------------------------------------------
LOCAL_OLLAMA_API_KEY=your-open-webui-api-key-here

# -----------------------------------------------------------------------------
# OpenAI API (https://platform.openai.com)
# Only required when ACTIVE_PROVIDER=openai
# Obtain API key: https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your-openai-api-key-here

# -----------------------------------------------------------------------------
# Nostr / Approval Gateway (NIP-17 DM approval flow)
# Generate with: nostr-sdk keygen or equivalent
# -----------------------------------------------------------------------------
APPROVAL_PRIVATE_KEY=your-nostr-approval-private-key-nsec
APPROVAL_PUBLIC_KEY=your-nostr-approval-public-key-npub

# -----------------------------------------------------------------------------
# Executor service JWT (inter-service auth between agent and executor)
# Must be >= 32 chars random
# -----------------------------------------------------------------------------
EXECUTOR_JWT_SECRET=CHANGE_ME_use_openssl_rand_hex_32
EXECUTOR_SERVICE_URL=http://executor:8001

# -----------------------------------------------------------------------------
# MFA / Authy (optional — used only if Authy MFA method is enabled)
# -----------------------------------------------------------------------------
AUTHY_API_KEY=your-authy-api-key-here

# -----------------------------------------------------------------------------
# ChromaDB (vector database)
# -----------------------------------------------------------------------------
CHROMA_HOST=localhost
CHROMA_PORT=8001

# -----------------------------------------------------------------------------
# Redis (session store / rate limiting)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
